# =============================================================================
# Lemzakov Data Room — environment variables
# Copy to .env (local) or set these in the Vercel project settings.
# Everything here is SERVER-SIDE only. Never expose the service account key or
# OAuth secret to the browser.
# =============================================================================

# --- Storage (Redis) ---------------------------------------------------------
# Durable store for synced HTML, project files, project config, sessions & ACLs.
# Provided by the Vercel Redis integration (redis:// or rediss://).
REDIS_URL=redis://default:password@host:6379

# --- Google Drive sync (service account — REQUIRED for private folders) -------
# A Google Cloud service account JSON key, raw JSON or base64-encoded JSON
# (base64 is safer in Vercel env vars, which mangle multi-line PEM keys):
#   base64 -w0 service-account.json
# Share each Drive folder (single-file source folder AND every project folder)
# with this service account's client_email as "Viewer".
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional fallback: an API key (only works for fully public folders; cannot
# reliably enumerate private folders). Prefer the service account above.
GOOGLE_API_KEY=

# --- Single-file publishing flow (existing) ----------------------------------
# The Drive folder that feeds the single-file pages (served at /<slug>).
# Provide the folder ID or a full Drive folder link.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_LINK=

# Secret guarding /api/sync, /api/diagnose and /secret-refresh?run=1.
SYNC_SECRET=

# --- Admin (/admin + project & page management APIs) -------------------------
# Password for the /admin dashboard (username is "admin") and bearer token for
# /api/admin/*. Falls back to SYNC_SECRET if unset.
ADMIN_TOKEN=

# --- Google OAuth (viewer sign-in) -------------------------------------------
# OAuth 2.0 "Web application" client. Add this authorized redirect URI in the
# Google Cloud console:  https://<your-domain>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override if the callback URL differs from the request-origin default.
GOOGLE_OAUTH_REDIRECT_URI=

# --- Scheduled project sync (Vercel Cron) ------------------------------------
# Secret for /api/projects-sync. Vercel Cron sends it as a Bearer token.
# Falls back to SYNC_SECRET if unset. The schedule lives in vercel.json
# (default: every 15 minutes) — edit it there to change the interval.
CRON_SECRET=

# --- Telegram access-request approvals (single-file pages) -------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
