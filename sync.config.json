{
  "googleDrive": {
    "folderIdEnv": "GOOGLE_DRIVE_FOLDER_ID",
    "folderLinkEnv": "GOOGLE_DRIVE_FOLDER_LINK",
    "apiKeyEnv": "GOOGLE_API_KEY",
    "serviceAccountEnv": "GOOGLE_SERVICE_ACCOUNT_JSON"
  },
  "sync": {
    "secretEnv": "SYNC_SECRET",
    "schedule": "*/30 * * * *"
  },
  "storage": {
    "htmlPrefix": "html"
  }
}
