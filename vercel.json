{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "*/30 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/secret-refresh",
      "dest": "/api/secret-refresh"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/([^/]+)",
      "dest": "/api/html?slug=$1"
    }
  ]
}
