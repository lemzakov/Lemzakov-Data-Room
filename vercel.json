{
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "*/30 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/secret-refresh",
      "dest": "/api/secret-refresh"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/([^/]+)",
      "dest": "/api/html?slug=$1"
    }
  ]
}
